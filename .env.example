# -------------------------------------------------------
# App
# -------------------------------------------------------
APP_NAME="The Slice Report"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://the-slice-report.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

# -------------------------------------------------------
# Logging
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------
# Database — MySQL
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=slice_report
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------------------------------
# Session, Cache & Queue — all using the DB for simplicity
# Switch cache/queue to Redis in production for performance
# -------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# -------------------------------------------------------
# Filesystem
# -------------------------------------------------------
FILESYSTEM_DISK=local

# -------------------------------------------------------
# Mail
# Log driver locally — no emails actually sent
# Switch to smtp/ses/postmark for production
# -------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@theslicereport.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Sanctum & Frontend
# SANCTUM_STATEFUL_DOMAINS: domains that can use cookie-based auth
# FRONTEND_URL: used by CORS config to allow the React dev server
# -------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:5173
FRONTEND_URL=http://localhost:5173
